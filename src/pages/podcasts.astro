---
import BaseLayout from "../layouts/BaseLayout.astro";

const podcasts = [
  {
    title: "SA Fireside Chat",
    description:
      "Intimate conversations and interviews with members sharing their experience, strength, and hope in recovery.",
    url: "https://safireside.com/",
    icon: "icon-mbri-play",
  },
  {
    title: "The Daily Reprieve",
    description:
      "A daily recovery podcast with talks, shares, and reflections from the fellowship.",
    url: "https://www.thedailyreprieve.com/",
    icon: "icon-mbri-music",
  },
  {
    title: "ESSAY Audio Recordings",
    description:
      "Listen to selected stories and articles from ESSAY Magazine, read aloud for convenience.",
    url: "https://essay.sa.org/recordings/?language=en",
    icon: "icon-mbri-desktop",
  },
];
---

<BaseLayout
  title="SA Podcasts"
  description="Listen to recovery podcasts and audio resources from Sexaholics Anonymous and related fellowship media."
  image="/assets/images/intro1.webp"
  legacyTheme={true}
>
  <section class="dtr-section hero-section-top-padding bg-purple">
    <div class="container dtr-py-100">
      <div class="row">
        <div class="col-12 text-center">
          <h1 class="color-orange dtr-mb-20">Recovery podcasts</h1>
          <p class="color-white text-size-lg">Listen to experience, strength, and hope on the go.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="dtr-section dtr-py-100">
    <div class="container">
      <div class="row dtr-mb-50">
        <div class="col-12 text-center">
          <h2 class="color-red">Featured audio resources</h2>
          <p class="text-size-md">Explore recommended audio resources created by and for members of the fellowship.</p>
        </div>
      </div>

      <div class="row justify-content-center">
        {podcasts.map((podcast) => (
          <div class="col-12 col-md-6 col-lg-4 dtr-mb-30">
            <div class="dtr-feature-top h-100 d-flex flex-column justify-content-between p-4 border-light rounded shadow-sm bg-light-purple text-center">
              <div class="dtr-feature-img dtr-mb-20">
                <i class={`${podcast.icon} color-red`} style="font-size: 3rem;"></i>
              </div>
              <div class="dtr-feature-content flex-grow-1">
                <h4 class="color-orange dtr-mb-15">{podcast.title}</h4>
                <p class="dtr-mb-20">{podcast.description}</p>
              </div>
              <div class="dtr-mt-20">
                <a href={podcast.url} target="_blank" rel="noopener noreferrer" class="dtr-btn btn-grad-orange w-100">
                  Listen Now &raquo;
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
