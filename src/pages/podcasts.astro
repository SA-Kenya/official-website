---
import BaseLayout from "../layouts/BaseLayout.astro";

const podcasts = [
  {
    title: "SA Fireside Chat",
    description:
      "Intimate conversations and interviews with members sharing their experience, strength, and hope in recovery.",
    url: "https://safireside.com/",
    icon: "🎙️",
  },
  {
    title: "The Daily Reprieve",
    description:
      "A daily recovery podcast with talks, shares, and reflections from the fellowship.",
    url: "https://www.thedailyreprieve.com/",
    icon: "🎧",
  },
  {
    title: "ESSAY Audio Recordings",
    description:
      "Listen to selected stories and articles from ESSAY Magazine, read aloud for convenience.",
    url: "https://essay.sa.org/recordings/?language=en",
    icon: "📻",
  },
];
---

<BaseLayout
  title="SA Podcasts"
  description="Listen to recovery podcasts and audio resources from Sexaholics Anonymous and related fellowship media."
  image="/assets/images/intro1.webp"
>
  <section class="section hero">
    <div class="container">
      <p class="eyebrow">Audio resources</p>
      <h1>Recovery podcasts</h1>
      <p class="lede">Listen to experience, strength, and hope on the go.</p>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <p class="eyebrow">Listen anywhere</p>
      <h2>Featured audio resources</h2>
      <p>Explore recommended audio resources created by and for members of the fellowship.</p>
      <div class="card-grid">
        {podcasts.map((podcast) => (
          <article class="resource-card col-4 feature-card">
            <span class="feature-icon" aria-hidden="true">{podcast.icon}</span>
            <h3>{podcast.title}</h3>
            <p>{podcast.description}</p>
            <a class="button" href={podcast.url} target="_blank" rel="noopener noreferrer">Listen now</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
