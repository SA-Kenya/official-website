---
import { navigation } from "../data/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href="/">
      <img src="/assets/images/SA-logo.png" alt="Sexaholics Anonymous Kenya logo" />
      <span>
        <strong>SA Kenya</strong>
        <small>Sexaholics Anonymous</small>
      </span>
    </a>

    <details class="nav-shell">
      <summary aria-label="Toggle menu">Menu</summary>
      <nav class="main-nav" aria-label="Primary">
        {navigation.map((item) => (
          <a href={item.href} class:list={{ active: isActive(item.href) }}>
            {item.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>
